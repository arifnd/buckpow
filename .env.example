# Flask
FLASK_ENV=development
SECRET_KEY=powerdash-dev-key-change-in-production

# Server
FLASK_HOST=0.0.0.0
FLASK_PORT=5001

# ── Database ──────────────────────────────────────────────
# Default: SQLite at instance/bakpow.db (no config needed)
#
# PostgreSQL:
#   DATABASE_URL=postgresql://user:pass@host:5432/dbname
#   (requires psycopg2-binary from requirements.txt)
#
# MySQL / MariaDB:
#   DATABASE_URL=mysql+pymysql://user:pass@host:3306/dbname
#   (requires pymysql from requirements.txt)
#
# DATABASE_URL=

# Logging
LOG_LEVEL=info

# Thresholds
DEVICE_ONLINE_TIMEOUT=30
DEFAULT_SAMPLING_INTERVAL=1
