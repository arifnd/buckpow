# App
APP_ENV=development
JWT_SECRET=powerdash-dev-key-change-in-production

# Admin (auto-created on first run if both are set)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your-secure-password

# Server
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Database ──────────────────────────────────────────────
# Default: SQLite at instance/buckpow.db (no config needed)
#
# PostgreSQL:
#   DATABASE_URL=postgresql://user:pass@host:5432/dbname
#   (requires psycopg2-binary from requirements.txt)
#
# MySQL / MariaDB:
#   DATABASE_URL=mysql+pymysql://user:pass@host:3306/dbname
#   (requires pymysql from requirements.txt)
#
# DATABASE_URL=

# API Documentation (FastAPI Swagger UI)
# Default: enabled when unset or set to "false"
# To disable /docs, /redoc, /openapi.json:
# DISABLE_API_DOCS=true

# Logging
LOG_LEVEL=info

# Thresholds
DEVICE_ONLINE_TIMEOUT=30
DEFAULT_SAMPLING_INTERVAL=1

# Device API key authentication
# Set to "false" to allow devices to send measurements without an API key
# (device_id from the payload is used for lookup instead)
# DEVICE_AUTH_ENABLED=true
